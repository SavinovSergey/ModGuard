# Модель
MODEL_TYPE=regex
MODEL_PATH=
#
# Если локальные артефакты BERT-модели отсутствуют, используется HuggingFace model-id.
# Можно выставить в пустое значение, чтобы отключить HF-фолбэк и не делать загрузку из сети.
BERT_HF_MODEL_NAME=SergeySavinov/rubert-tiny-toxicity

# Аналогично для RNN токсичности (используется как HF model-id при отсутствии локальных файлов).
RNN_HF_MODEL_NAME=SergeySavinov/rurnn-toxicity

# API
API_VERSION=v1
API_PREFIX=/api/v1

# Производительность
MAX_BATCH_SIZE=1000
WORKERS=4

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=json

# Сервер
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Очереди и хранилище (для воркера, listener, actions, validate_chain, clear_redis)
# Локальный запуск скриптов на хосте: используйте localhost (redis://localhost:6379/0, postgresql://...@localhost:...).
# В Docker контейнерах задаётся через docker-compose (redis://redis:6379/0 и т.д.).
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/modguard
REDIS_URL=redis://localhost:6379/0

# Telegram (для listener-telegram и actions-telegram, профиль telegram в docker-compose)
TELEGRAM_BOT_TOKEN=
